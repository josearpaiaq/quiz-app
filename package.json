{
  "name": "multiplayer-quiz-app",
  "private": true,
  "scripts": {
    "dev:shared": "pnpm --filter @quiz/shared dev",
    "dev:backend": "pnpm --filter @quiz/shared build && pnpm --filter @quiz/backend dev",
    "dev:frontend": "pnpm --filter @quiz/frontend dev",
    "build:shared": "pnpm --filter @quiz/shared build",
    "build:backend": "pnpm --filter @quiz/shared build && pnpm --filter @quiz/backend build",
    "build:frontend": "pnpm --filter @quiz/frontend build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
